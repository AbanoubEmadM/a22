<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.a2.ui.SetBudgetController"
      spacing="15"
      style="-fx-padding: 20;">

    <Label text="Set Budget" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="100"/>
            <ColumnConstraints minWidth="300" prefWidth="300"/>
        </columnConstraints>

        <Label text="Category:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="categoryComboBox" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="300"/>

        <Label text="Amount:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="amountField" promptText="0.00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Month:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="monthComboBox" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="300"/>

        <Label text="Year:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="yearComboBox" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="300"/>
    </GridPane>

    <Label fx:id="errorLabel" textFill="red" visible="false"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Save" onAction="#handleSave" prefWidth="100"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Button text="Cancel" onAction="#handleCancel" prefWidth="100"
                style="-fx-background-color: #9E9E9E; -fx-text-fill: white;"/>
    </HBox>
</VBox>
