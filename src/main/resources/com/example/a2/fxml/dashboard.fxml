<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.a2.ui.DashboardController"
            prefWidth="1000" prefHeight="700">

    <!-- Top Bar -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #2196F3; -fx-padding: 15;">
            <Label fx:id="welcomeLabel" text="Welcome, User" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">

            <!-- Summary Cards -->
            <HBox spacing="20" alignment="CENTER">
                <VBox spacing="5" style="-fx-background-color: #4CAF50; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                    <Label text="Monthly Income" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    <Label fx:id="incomeLabel" text="\$0.00" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #f44336; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                    <Label text="Monthly Expense" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    <Label fx:id="expenseLabel" text="\$0.00" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #FF9800; -fx-padding: 20; -fx-background-radius: 10;" HBox.hgrow="ALWAYS">
                    <Label text="Balance" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    <Label fx:id="balanceLabel" text="\$0.00" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- Tabs -->
            <TabPane VBox.vgrow="ALWAYS">

                <!-- Transactions Tab -->
                <Tab text="Transactions" closable="false">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="Add Transaction" onAction="#handleAddTransaction"
                                    style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                            <Button text="Delete Selected" onAction="#handleDeleteTransaction"
                                    style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Refresh" onAction="#refreshData"
                                    style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                        </HBox>

                        <TableView fx:id="transactionsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="dateColumn" text="Date" prefWidth="100"/>
                                <TableColumn fx:id="typeColumn" text="Type" prefWidth="100"/>
                                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
                                <TableColumn fx:id="amountColumn" text="Amount" prefWidth="100"/>
                                <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="300"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- Budgets Tab -->
                <Tab text="Budgets" closable="false">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button text="Set Budget" onAction="#handleSetBudget"
                                    style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                        </HBox>

                        <TableView fx:id="budgetsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="budgetCategoryColumn" text="Category" prefWidth="200"/>
                                <TableColumn fx:id="budgetAmountColumn" text="Budget" prefWidth="100"/>
                                <TableColumn fx:id="spentColumn" text="Spent" prefWidth="100"/>
                                <TableColumn fx:id="remainingColumn" text="Remaining" prefWidth="100"/>
                                <TableColumn fx:id="percentageColumn" text="Used %" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- Reports Tab -->
                <Tab text="Monthly Report" closable="false">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Month:"/>
                            <ComboBox fx:id="monthComboBox" prefWidth="150"/>
                            <Label text="Year:"/>
                            <ComboBox fx:id="yearComboBox" prefWidth="100"/>
                            <Button text="Generate Report" onAction="#handleGenerateReport"
                                    style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                        </HBox>

                        <TextArea fx:id="reportTextArea" editable="false" VBox.vgrow="ALWAYS"
                                  style="-fx-font-family: 'Courier New'; -fx-font-size: 12px;"/>
                    </VBox>
                </Tab>
            </TabPane>
        </VBox>
    </center>
</BorderPane>
