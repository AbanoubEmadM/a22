<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.a2.ui.LoginController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label text="Personal Budgeting System" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;">
        <Label text="Email:" style="-fx-font-size: 14px;"/>
        <TextField fx:id="emailField" promptText="Enter email" prefWidth="300"/>

        <Label text="Password:" style="-fx-font-size: 14px;"/>
        <PasswordField fx:id="passwordField" promptText="Enter password" prefWidth="300"/>

        <Label fx:id="errorLabel" textFill="red" style="-fx-font-size: 12px;" visible="false"/>

        <HBox spacing="10" alignment="CENTER">
            <Button text="Login" onAction="#handleLogin" prefWidth="140"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button text="Register" onAction="#handleRegister" prefWidth="140"
                    style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px;"/>
        </HBox>
    </VBox>
</VBox>
